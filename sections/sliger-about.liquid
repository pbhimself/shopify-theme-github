<div class="sliger-page">
  <section class="sliger-page-heading">
    <div class="sliger-page-heading__media" aria-hidden="true">
      <img src="{{ 'sliger-clean-skin-poster.png' | asset_url }}" alt="" width="1024" height="1536" loading="eager">
    </div>
    <div class="sliger-shell">
      <p class="sliger-eyebrow">About SLIGER</p>
      <h1>Premium skincare curation by Pratik Bhangale.</h1>
      <p>
        SLIGER is built for people who want a cleaner skincare buying experience:
        fewer distractions, practical benefits, beautiful visuals, and direct Amazon
        affiliate links.
      </p>
    </div>
  </section>

  <section class="sliger-section">
    <div class="sliger-shell sliger-grid-2">
      <div class="sliger-card sliger-featured__media">
        <img src="{{ 'sliger-minimalist-cleanser.jpg' | asset_url }}" alt="Minimalist Alpha Lipoic and Glycolic Cleanser" width="726" height="1000" loading="lazy">
      </div>
      <div>
        <p class="sliger-eyebrow">Founder note</p>
        <h2 class="sliger-title">A clean store without checkout noise.</h2>
        <p class="sliger-copy">
          Pratik Bhangale created SLIGER as a modern affiliate skincare destination
          that helps shoppers compare focused cleanser picks without pretending to be a
          full ecommerce store. The experience is direct: understand the product,
          click the affiliate button, and purchase on Amazon.
        </p>
        <div class="sliger-hero__actions">
          <a class="sliger-button" href="{{ routes.root_url }}#shop">Explore products</a>
          <a class="sliger-button-secondary" href="/pages/contact">Contact Us</a>
        </div>
      </div>
    </div>
  </section>

  <section class="sliger-section sliger-soft-band">
    <div class="sliger-shell">
      <p class="sliger-eyebrow sliger-title--center">Brand values</p>
      <h2 class="sliger-title sliger-title--center">Luxury, clarity, and honest affiliate shopping.</h2>
      <div class="sliger-grid-4" style="margin-top: 34px;">
        <article class="sliger-card sliger-value">
          <span class="sliger-value__icon">1</span>
          <h3>Clean curation</h3>
          <p>SLIGER highlights fewer products with clearer reasons, so shoppers can move with confidence.</p>
        </article>
        <article class="sliger-card sliger-value">
          <span class="sliger-value__icon">2</span>
          <h3>Skin comfort first</h3>
          <p>The brand favors simple, repeatable skincare routines for both men and women.</p>
        </article>
        <article class="sliger-card sliger-value">
          <span class="sliger-value__icon">3</span>
          <h3>Transparent affiliate model</h3>
          <p>Buttons open Amazon. SLIGER does not run checkout, payments, or delivery.</p>
        </article>
        <article class="sliger-card sliger-value">
          <span class="sliger-value__icon">4</span>
          <h3>Premium visual experience</h3>
          <p>Every layout is designed to feel calm, polished, mobile-first, and easy to scan.</p>
        </article>
      </div>
    </div>
  </section>

  <section class="sliger-section">
    <div class="sliger-shell">
      <div class="sliger-cta">
        <p class="sliger-eyebrow" style="color: var(--sliger-glacier);">Purchase notice</p>
        <h2>No cart. No checkout. No payment gateway.</h2>
        <p>
          SLIGER exists to help visitors choose products. All final product details,
          pricing, delivery, and purchase actions happen on Amazon.
        </p>
        <div class="sliger-hero__actions">
          <a class="sliger-button-secondary" href="/pages/privacy-policy">Privacy Policy</a>
        </div>
      </div>
    </div>
  </section>
</div>

{% schema %}
{
  "name": "SLIGER about",
  "presets": [
    {
      "name": "SLIGER about"
    }
  ]
}
{% endschema %}
